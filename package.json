{
  "name": "imglint",
  "version": "1.1.4",
  "description": "A tool for checking image files",
  "bin": {
    "imglint": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "rm -rf ./dist && tsc -p tsconfig.build.json && chmod +x ./dist/cli.js",
    "start": "npm run build && node ./dist/cli.js",
    "test": "vitest src/**/*.test.ts --silent=false",
    "lint": "eslint src/**/*.ts",
    "format": "prettier src/**/*.ts --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartram/imglint.git"
  },
  "keywords": [
    "lint",
    "image",
    "exif",
    "iptc"
  ],
  "type": "module",
  "author": "Bartram Nason <bartram@bartramnason.com>",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "exifr": "^7.1.3",
    "findup-sync": "^5.0.0",
    "image-size": "^2.0.2",
    "lodash-es": "^4.17.23",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.3",
    "@types/findup-sync": "^4.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.16"
  }
}
